std_msgs/Header header                    # 消息头：主要用于时间戳

float64 vx                                # 机器人期望前向速度，单位 m/s
float64 vy                                # 机器人期望侧向速度，单位 m/s
float64 wz                                # 机器人期望偏航角速度，单位 rad/s
float64 body_height                       # 机器人期望机身高度，单位 m